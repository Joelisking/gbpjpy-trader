# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv/

# Large raw data files — download locally with download_dukascopy.py, don't commit
# Scalers (scaler_*.pkl) are excluded from this rule — needed for VPS inference
data/*
!data/.gitkeep
!data/scaler_*.pkl

# Model backups — v1/v2 are labelled backup files, don't commit
models/*_v1.*
models/*_v2.*

# Live database — VPS manages its own
db/trades.db

# Logs
logs/*.log

# Backtest HTML reports — large, keep locally
backtest_results/*.html
!backtest_results/*.json    # walk-forward results — small, useful on VPS

# Secrets — NEVER commit
config.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
